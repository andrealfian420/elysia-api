APP_NAME=elysia-api
NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/db_elysia?schema=public"
REDIS_URL="redis://localhost:6379"

# generate with 'node -e "console.log(require('crypto').randomBytes(128).toString('hex'))"'
JWT_ACCESS_SECRET=access-secret

ACCESS_TOKEN_EXPIRES=10m
REFRESH_TOKEN_EXPIRY_DAY=7
BCRYPT_SALT_ROUNDS=12